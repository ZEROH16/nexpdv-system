{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"],
    "noEmit": false,
    "outDir": "dist/main"
  },
  "include": ["src/main/**/*.ts"]
}
